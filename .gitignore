node_modules/
dist/
.vite/
*.log
.DS_Store
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# Imported raw audio (keep generated chart data)
import/*.wav
import/*.WAV
!import/.gitkeep

# Generated song data (audio + chart per song folder).
# Keep song-list.json structure but exclude individual song folders since
# they're derived from user-provided audio files which we don't ship.
public/songs/*/
!public/songs/.gitkeep
public/songs/song-list.json

# Menu BGM audio file (user-supplied; may be copyrighted or large)
public/bgm/*.wav
public/bgm/*.ogg
public/bgm/*.mp3

# IDE
.idea/
.vscode/
*.swp
